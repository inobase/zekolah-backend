# Server
NODE_ENV=development
PORT=3000
HOST=localhost

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zekolah
DB_USER=root
DB_PASS=

# JWT
JWT_SECRET=zekolah-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS
# Development (leave empty or uncomment for wildcard): CORS_ORIGIN=*
# Local: CORS_ORIGIN=http://localhost:3001,http://localhost:5173
# Production: CORS_ORIGIN=https://app.zekolah.com,https://admin.zekolah.com
CORS_ORIGIN=http://localhost:3001,http://localhost:5173

# Logging
LOG_LEVEL=info

# Bcrypt
BCRYPT_ROUNDS=10
