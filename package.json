{
  "name": "zekolah-backend",
  "version": "1.0.2",
  "description": "Zekolah Backend - Educational Management System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "migrate": "node scripts/migrate.js latest",
    "migrate:rollback": "node scripts/migrate.js rollback",
    "migrate:make": "knex migrate:make",
    "seed": "node scripts/migrate.js seed",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "education",
    "management",
    "school-system"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "dayjs": "^1.11.13",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "knex": "^3.1.0",
    "moment": "^2.30.1",
    "mysql2": "^3.11.0",
    "passport-local": "^1.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "knex-migrator": "^5.3.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
