{
  "name": "zekolah-backend",
  "version": "1.0.4",
  "description": "Zekolah Backend - Educational Management System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "migrate": "tsx scripts/migrate.js latest",
    "migrate:rollback": "tsx scripts/migrate.js rollback",
    "migrate:make": "knex migrate:make",
    "seed": "tsx scripts/migrate.js seed",
    "db:check": "node scripts/check-tables.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "education",
    "management",
    "school-system"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "knex": "^3.1.0",
    "mysql2": "^3.11.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  }
}
